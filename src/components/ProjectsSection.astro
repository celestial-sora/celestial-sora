---
---
<section class="section projects-section" id="projects">
    <div class="section-container">
        <div class="section-header">
            <span class="section-tag frosted-glass">
                <span class="section-tag-icon">
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor">
                        <path d="M12 2L14.85 9.15L22 12L14.85 14.85L12 22L9.15 14.85L2 12L9.15 9.15L12 2Z"></path>
                    </svg>
                </span>
                ผลงาน
            </span>
            <h2 class="section-title">My Creations</h2>
        </div>
        <div class="projects-grid">
            <!-- GitHub Profile Card -->
            <div class="project-card frosted-glass">
                <div class="project-info">
                    <div class="project-meta">
                        <span class="project-category">
                            <span class="project-cat-icon">
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M16 18l6-6-6-6M8 6l-6 6 6 6"></path>
                                </svg>
                            </span>
                            <span>GitHub Profile / Repositories</span>
                        </span>
                        <span class="project-status-badge beta">Active</span>
                    </div>
                    <h3 class="project-name">celestial-sora</h3>
                    <p class="project-desc">
                        คลังเก็บรวบรวมซอร์สโค้ด โปรเจกต์พัฒนาซอฟต์แวร์ และการ ทดลอง Ai ของฉัน บน GitHub สามารถเข้ามาดูและร่วมพัฒนาโปรเจกต์ต่างๆ ได้เลย!
                    </p>
                    <div class="project-tech-tags">
                        <span class="tech-tag frosted-glass">Git Repositories</span>
                        <span class="tech-tag frosted-glass">Open Source</span>
                        <span class="tech-tag frosted-glass">Something</span>
                        <span class="tech-tag frosted-glass">Vibe Coding</span>
                    </div>
                    <div class="project-buttons">
                        <a href="https://github.com/celestial-sora" target="_blank" rel="noopener noreferrer" class="btn btn-primary project-btn">
                            <span>ดูบน GitHub</span>
                            <span class="btn-arrow">
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Sora-Novel Card -->
            <div class="project-card frosted-glass">
                <div class="project-info">
                    <div class="project-meta">
                        <span class="project-category">
                            <span class="project-cat-icon">
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                                </svg>
                            </span>
                            <span>Interactive Novel / AI</span>
                        </span>
                        <span class="project-status-badge beta">Dynamic Branch</span>
                    </div>
                    <h3 class="project-name">Sora-Novel</h3>
                    <p class="project-desc">
                        นิยายอินเทอร์แอกทีฟที่ตัวเลือกของคุณกำหนดเส้นทางเรื่อง ขับเคลื่อนด้วย AI Memory System ที่จดจำบริบทและสถานะของเรื่องไปตลอด — เนื้อเรื่องเขียนโดยมนุษย์ ความจำขับเคลื่อนโดย AI
                    </p>
                    <div class="project-tech-tags">
                        <span class="tech-tag frosted-glass">AI Memory</span>
                        <span class="tech-tag frosted-glass">Dynamic Branch</span>
                        <span class="tech-tag frosted-glass">Interactive Story</span>
                        <span class="tech-tag frosted-glass">Next.js</span>
                    </div>
                    <div class="project-buttons">
                        <a href="https://sora-novel.vercel.app/" target="_blank" rel="noopener noreferrer" class="btn btn-primary project-btn">
                            <span>เล่นเลย</span>
                            <span class="btn-arrow">
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </span>
                        </a>
                        <a href="https://github.com/celestial-sora/Sora-Novel" target="_blank" rel="noopener noreferrer" class="btn btn-outline project-btn">
                            <span>GitHub</span>
                            <span class="btn-arrow">
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                                    <path d="M10.226 17.284c-2.965-.36-5.054-2.493-5.054-5.256 0-1.123.404-2.336 1.078-3.144-.292-.741-.247-2.314.09-2.965.898-.112 2.111.36 2.83 1.01.853-.269 1.752-.404 2.853-.404 1.1 0 1.999.135 2.807.382.696-.629 1.932-1.1 2.83-.988.315.606.36 2.179.067 2.942.72.854 1.101 2 1.101 3.167 0 2.763-2.089 4.852-5.098 5.234.763.494 1.28 1.572 1.28 2.807v2.336c0 .674.561 1.056 1.235.786 4.066-1.55 7.255-5.615 7.255-10.646C23.5 6.188 18.334 1 11.978 1 5.62 1 .5 6.188.5 12.545c0 4.986 3.167 9.12 7.435 10.669.606.225 1.19-.18 1.19-.786V20.63a2.9 2.9 0 0 1-1.078.224c-1.483 0-2.359-.808-2.987-2.313-.247-.607-.517-.966-1.034-1.033-.27-.023-.359-.135-.359-.27 0-.27.45-.471.898-.471.652 0 1.213.404 1.797 1.235.45.651.921.943 1.483.943.561 0 .92-.202 1.437-.719.382-.381.674-.718.944-.943"></path>
                                </svg>
                            </span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
