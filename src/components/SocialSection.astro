---
---
<section class="section social-section" id="social">
    <div class="section-container">
        <div class="section-header">
            <span class="section-tag frosted-glass">
                <span class="section-tag-icon">
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor">
                        <path d="M12 2L14.85 9.15L22 12L14.85 14.85L12 22L9.15 14.85L2 12L9.15 9.15L12 2Z"></path>
                    </svg>
                </span>
                สนับสนุน & โซเชียลมีเดีย
            </span>
            <h2 class="section-title">Support & Connect</h2>
        </div>

        <!-- Donation & Support Hub (High Priority, Above Socials) -->
        <div class="donation-hub-container frosted-glass reveal" id="donate">
            <div class="donation-hub-header">
                <span class="donation-hub-tag frosted-glass">
                    <span class="donation-hub-tag-icon">
                        <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor">
                            <path d="M12 2L14.85 9.15L22 12L14.85 14.85L12 22L9.15 14.85L2 12L9.15 9.15L12 2Z"></path>
                        </svg>
                    </span>
                    Donate / สนับสนุน
                </span>
                <h3 class="donation-hub-title">สนับสนุน Sora Astralis</h3>
                <p class="donation-hub-subtitle">โดเนทเพื่อให้โผมมมคอสเพลย์/แต่งหญิง หรือสนับสนุน ผ่านทางช่องทางหลักทั้งสองด้านล่างนี้ได้เลยยย</p>
            </div>
            <div class="donation-cards-wrapper">
                <!-- Happy Donate Card -->
                <a href="https://happydonate.app/sora" target="_blank" rel="noopener noreferrer" class="donation-main-card happydonate-main frosted-glass">
                    <div class="donation-badge-hot">Direct</div>
                    <div class="donation-card-content">
                        <div class="donation-logo-area">
                            <img src={import.meta.env.BASE_URL + "happydonate-logo.png"} alt="Happy Donate Logo" class="brand-icon" />
                            <div class="donation-brand">
                                <h4>Happy Donate</h4>
                                <span>สนับสนุนช่องทางนี้ได้เลยย</span>
                            </div>
                        </div>
                        <p class="donation-desc">โดเนทผ่าน Happy Donate ได้เลยน้า</p>
                        <div class="donation-btn-accent">
                            <span>โดเนทผ่าน Happy Donate</span>
                            <span class="arrow-icon">
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </span>
                        </div>
                    </div>
                </a>

                <!-- EasyDonate Card -->
                <a href="https://easydonate.app/sorapurr" target="_blank" rel="noopener noreferrer" class="donation-main-card easydonate-main frosted-glass">
                    <div class="donation-badge-hot">Direct</div>
                    <div class="donation-card-content">
                        <div class="donation-logo-area">
                            <img src={import.meta.env.BASE_URL + "easydonate-logo.ico"} alt="EasyDonate Logo" class="brand-icon" />
                            <div class="donation-brand">
                                <h4>EasyDonate</h4>
                                <span>สนับสนุนช่องทางนี้ได้เลยย</span>
                            </div>
                        </div>
                        <p class="donation-desc">โดเนทเริ่มต้น 1 บาท ขึ้นจอ 10 บาท</p>
                        <div class="donation-btn-accent">
                            <span>โดเนทผ่าน EasyDonate</span>
                            <span class="arrow-icon">
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </span>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        <!-- Follow Grid (Secondary, below donations) -->
        <div class="social-grid-header reveal">
            <span class="grid-subtag">
                <span class="grid-subtag-icon">
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor">
                        <path d="M12 2L14.85 9.15L22 12L14.85 14.85L12 22L9.15 14.85L2 12L9.15 9.15L12 2Z"></path>
                    </svg>
                </span>
                ติดตามช่องทางอื่นๆ
            </span>
            <h4 class="grid-subtitle">Follow My Journey</h4>
        </div>

        <div class="social-grid">
            <a href="https://www.tiktok.com/@celestial.s0ra" target="_blank" rel="noopener noreferrer" class="social-card tiktok reveal frosted-glass" id="social-tiktok">
                <div class="social-icon-wrapper">
                    <svg class="social-svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.88a8.28 8.28 0 004.76 1.51V6.94a4.84 4.84 0 01-1-.25z"></path>
                    </svg>
                </div>
                <div class="social-info">
                    <h3 class="social-name">TikTok</h3>
                    <p class="social-handle">@celestial.s0ra</p>
                </div>
                <span class="social-arrow">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </span>
            </a>
            <a href="https://www.instagram.com/sphle_sora/" target="_blank" rel="noopener noreferrer" class="social-card instagram reveal frosted-glass" id="social-instagram">
                <div class="social-icon-wrapper">
                    <svg class="social-svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"></path>
                    </svg>
                </div>
                <div class="social-info">
                    <h3 class="social-name">Instagram</h3>
                    <p class="social-handle">@sphle_sora</p>
                </div>
                <span class="social-arrow">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </span>
            </a>
            <a href="https://www.youtube.com/@sorachanXZ-d1r" target="_blank" rel="noopener noreferrer" class="social-card youtube reveal frosted-glass" id="social-youtube">
                <div class="social-icon-wrapper">
                    <svg class="social-svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"></path>
                    </svg>
                </div>
                <div class="social-info">
                    <h3 class="social-name">YouTube</h3>
                    <p class="social-handle">Sora Astralis</p>
                </div>
                <span class="social-arrow">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </span>
            </a>
            <a href="https://discord.com/users/1433232573202698302" target="_blank" rel="noopener noreferrer" class="social-card discord reveal frosted-glass" id="social-discord">
                <div class="social-icon-wrapper">
                    <svg class="social-svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"></path>
                    </svg>
                </div>
                <div class="social-info">
                    <h3 class="social-name">Discord</h3>
                    <p class="social-handle">Direct Message</p>
                </div>
                <span class="social-arrow">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </span>
            </a>
        </div>
    </div>
</section>
