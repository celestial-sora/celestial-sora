---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Sora Chan", 
	description = "if u see this 'this is a bug but idk how to fix it then i trun it to feature'" 
} = Astro.props;
---
<!doctype html>
<html lang="th" data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href={import.meta.env.BASE_URL + "favicon.png"} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@600&family=Inter:wght@300;400;500;600;700;800;900&family=Itim&family=Noto+Sans+Thai:wght@300;400;500;600;700;800;900&family=Pacifico&family=Dancing+Script:wght@700&display=swap" rel="stylesheet" />
		<script is:inline>
			const savedTheme = localStorage.getItem('sora-theme') || 'dark';
			document.documentElement.setAttribute('data-theme', savedTheme);
		</script>
	</head>
	<body class="is-loading">
		<slot />
	</body>
</html>
